                currentHumanoid.Health = currentHumanoid.MaxHealth
            end
        end
    end
    
    local characterAddedConnection = LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait()
        updateCharacter()
        applyGodMode()
    end)
    
    godModeConnection = RunService.Heartbeat:Connect(applyGodMode)
    applyGodMode()
end

