local function interpolatePosition(pos1, pos2, t)
    return pos1 + (pos2 - pos1) * t
end

local function interpolateRotation(rot1, rot2, t)
    local diff = rot2 - rot1
    while diff > math.pi do diff = diff - 2 * math.pi end
    while diff < -math.pi do diff = diff + 2 * math.pi end
    return rot1 + diff * t
end

local function stopAutoWalk(resetUI)
    if walkConnection then
        walkConnection:Disconnect()
        walkConnection = nil
    end
    
    if currentRootPart then
        currentRootPart.Anchored = false
    end
    
    if currentHumanoid then
        currentHumanoid:Move(Vector3.zero, false)
        currentHumanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
    end
    
    autoWalkActive = false
    autoWalkPaused = false
end

local function startAutoWalk(checkpointData, onComplete)
    if not checkpointData or #checkpointData == 0 then
        if onComplete then onComplete() end
        return
    end
    
    if autoWalkActive then stopAutoWalk(false) end
    
    if currentRootPart and currentHumanoid then
        local firstPos = checkpointData[1].position
        local pos = Vector3.new(firstPos.x, firstPos.y + (checkpointData[1].hipHeight or 2), firstPos.z)
        currentRootPart.CFrame = CFrame.new(pos) * CFrame.Angles(0, checkpointData[1].rotation or 0, 0)
        currentRootPart.AssemblyLinearVelocity = Vector3.zero
        currentRootPart.AssemblyAngularVelocity = Vector3.zero
    end
    
    autoWalkActive = true
    autoWalkPaused = false
    
    local currentTime = 0
    local lastTime = tick()
    local currentCpIndex = 1
    local isFirstRun = true
    local targetRotation = 0
    
    walkConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if not autoWalkActive or autoWalkPaused then return end
        if not currentCharacter or not currentRootPart or not currentHumanoid then
            updateCharacter()
            if not currentCharacter then return end
        end
        
        local now = tick()
        local dt = math.min(now - lastTime, 0.1) * autoWalkSpeed
        lastTime = now
        
        if autoWalkFlipped then
            currentTime = currentTime - dt
        else
            currentTime = currentTime + dt
        end
        
        local totalTime = checkpointData[#checkpointData].time
        if currentTime > totalTime then
            if autoWalkLoop then
                if autoRespawn and currentHumanoid then
                    currentHumanoid.Health = 0
                    task.wait(1)
                    updateCharacter()
                end
                currentTime = checkpointData[1].time
                currentCpIndex = 1
                isFirstRun = true
            else
                stopAutoWalk(true)
                if onComplete then onComplete() end
                return
            end
        elseif currentTime < checkpointData[1].time then
            if autoWalkLoop then
                currentTime = checkpointData[#checkpointData].time
                currentCpIndex = #checkpointData - 1
            else
                stopAutoWalk(true)
                if onComplete then onComplete() end
                return
            end
        end
        
        while currentCpIndex < #checkpointData and checkpointData[currentCpIndex + 1].time < currentTime do
            currentCpIndex = currentCpIndex + 1
        end
        while currentCpIndex > 1 and checkpointData[currentCpIndex - 1].time > currentTime do
            currentCpIndex = currentCpIndex - 1
        end
        
        local cp1 = checkpointData[currentCpIndex]
        local cp2 = checkpointData[currentCpIndex + 1] or cp1
        
        local t = (cp1.time == cp2.time) and 0 or (currentTime - cp1.time) / (cp2.time - cp1.time)
        t = math.clamp(t, 0, 1)
        
        local pos1 = Vector3.new(cp1.position.x, cp1.position.y, cp1.position.z)
        local pos2 = Vector3.new(cp2.position.x, cp2.position.y, cp2.position.z)
        local currentPos = interpolatePosition(pos1, pos2, t)
        currentPos = Vector3.new(currentPos.X, currentPos.Y + (cp1.hipHeight or 2), currentPos.Z)
        
        local vel1 = cp1.velocity or Vector3.zero
        local vel2 = cp2.velocity or Vector3.zero
        local currentVel = interpolatePosition(vel1, vel2, t)
        
        local rot1 = cp1.rotation or 0
        local rot2 = cp2.rotation or 0
        local currentRot = interpolateRotation(rot1, rot2, t)
        
        local targetCFrame = CFrame.new(currentPos) * CFrame.Angles(0, currentRot, 0)
        
        if autoWalkFlipped then
            targetCFrame = targetCFrame * CFrame.Angles(0, math.pi, 0)
        end
        
        local lerpSpeed = math.clamp(1 - math.exp(-12 * dt), 0, 1)
        currentRootPart.CFrame = currentRootPart.CFrame:Lerp(targetCFrame, lerpSpeed)
        
        pcall(function()
            currentRootPart.AssemblyLinearVelocity = currentVel
        end)
        
        if currentHumanoid then
            currentHumanoid:Move(currentVel, false)
            
            local isJumping = (cp1.jumping or cp2.jumping) or false
            if isJumping and not autoWalkPaused then
                currentHumanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
        
        onWalk()
    end)
end

-- ==================== CHECKPOINT FUNCTIONS ====================
local function generateCheckpointList(track)
    local files = {}
    if track.spawnpoint then
        table.insert(files, "spawnpoint.json")
    end
    
    local specials = track.specialCheckpoints or {}
    table.sort(specials, function(a, b) return a.position < b.position end)
    
    for i = 1, track.checkpointCount do
        local specialIndex = 1
        while specialIndex <= #specials and specials[specialIndex].position < i do
            specialIndex = specialIndex + 1
        end
        
        if specialIndex <= #specials and specials[specialIndex].position == i then
            table.insert(files, specials[specialIndex].file)
        end
        table.insert(files, string.format("checkpoint_%d.json", i))
    end
    
    return files
end

local function setupTrack(trackName)
    local track = tracks[trackName]
    if not track then return end
    
    local trackFolder = auth.folder .. "/" .. track.folder
    if not isfolder(trackFolder) then
        makefolder(trackFolder)
        WindUI:Notify({
            Title = "Track Setup",
            Content = "Folder " .. track.folder .. " dibuat!",
            Duration = 2,
            Icon = "folder-plus"
        })
    end
    
    local files = generateCheckpointList(track)
    local missingFiles = {}
    
    for _, file in ipairs(files) do
        if not isfile(trackFolder .. "/" .. file) then
            table.insert(missingFiles, file)
        end
    end
    
    if #missingFiles > 0 then
        WindUI:Notify({
            Title = "Auto Download",
            Content = "Mendeteksi " .. #missingFiles .. " file belum ada. Memulai download...",
            Duration = 3,
            Icon = "download"
        })
        
        task.spawn(function()
            local successCount = 0
            local failCount = 0
            
            for i, file in ipairs(missingFiles) do
                local success, content = pcall(function()
                    return game:HttpGet(track.url .. file)
                end)
                
                if success and content and #content > 0 then
                    writefile(trackFolder .. "/" .. file, content)
                    successCount = successCount + 1
                else
                    failCount = failCount + 1
                end
                
                if i % 5 == 0 or i == #missingFiles then
                    WindUI:Notify({
                        Title = "Downloading",
                        Content = string.format("Progress: %d/%d", i, #missingFiles),
                        Duration = 1.5,
                        Icon = "download"
                    })
                end
                task.wait(0.3)
            end
            
            WindUI:Notify({
                Title = "Download Selesai",
                Content = string.format("Berhasil: %d | Gagal: %d", successCount, failCount),
                Duration = 4,
                Icon = "check-check"
            })
        end)
    else
        WindUI:Notify({
            Title = "Track Ready",
            Content = "Semua checkpoint sudah tersedia!",
            Duration = 2,
            Icon = "circle-check"
        })
    end
    
    return files
end

local function loadTrack(trackName)
    local track = tracks[trackName]
    if not track then return end
    
    currentTrack = trackName
    currentTrackFolder = auth.folder .. "/" .. track.folder
    currentTrackUrl = track.url
    currentTrackFiles = generateCheckpointList(track)
    
    getgenv().AutoWalk_CurrentTrack = currentTrack
    getgenv().AutoWalk_CurrentJsonFolder = currentTrackFolder
    getgenv().AutoWalk_CurrentBaseURL = currentTrackUrl
    getgenv().AutoWalk_CurrentJsonFiles = currentTrackFiles
    
