-- ==================== UPDATE CHECKPOINT TAB ====================
local function setupUpdateCheckpointTab()
    local UpdateCheckpointTab = Window:Tab({
        Title = "Update Checkpoint",
        Icon = "file"
    })
    
    UpdateCheckpointTab:Section({
        Title = "MarV Script | Update Checkpoint",
        TextTransparency = 0.05,
        TextXAlignment = "Left",
        TextSize = 17
    })
    UpdateCheckpointTab:Divider()
    
    UpdateCheckpointTab:Paragraph({
        Title = "Update Checkpoint",
        Desc = "Berfungsi untuk mengupdate ulang semua checkpoint dari track yang sudah dipilih. Pastikan Anda sudah memilih track di menu Auto Walk terlebih dahulu."
    })
    UpdateCheckpointTab:Divider()
    
    local isUpdating = false
    local shouldStop = false
    
    UpdateCheckpointTab:Toggle({
        Title = "◉ UPDATE CHECKPOINT",
        Desc = "Berfungsi untuk mengupdate ulang semua checkpoint dari track yang dipilih.",
        Icon = "check",
        Type = "Checkbox",
        Value = false,
        Callback = function(state)
            if not state then
                shouldStop = true
                isUpdating = false
                return
            end
            
            local trackName = getgenv().AutoWalk_CurrentTrack
            local trackFolder = getgenv().AutoWalk_CurrentJsonFolder
            local trackUrl = getgenv().AutoWalk_CurrentBaseURL
            local trackFiles = getgenv().AutoWalk_CurrentJsonFiles
            
            if not trackName then
                WindUI:Notify({
                    Title = "Error",
                    Content = "Pilih track terlebih dahulu di menu Auto Walk!",
                    Duration = 3,
                    Icon = "alert-triangle"
                })
                return
            end
            
            isUpdating = true
            shouldStop = false
            
            task.spawn(function()
                WindUI:Notify({
                    Title = "Update Checkpoint",
                    Content = "Memulai proses update untuk " .. trackName .. "...",
                    Duration = 2,
                    Icon = "refresh-cw"
                })
                
                -- Delete existing files
                for _, file in ipairs(trackFiles) do
                    local filePath = trackFolder .. "/" .. file
                    if isfile(filePath) then
                        delfile(filePath)
                    end
                end
                
                local successCount = 0
                local failCount = 0
                
                for i, file in ipairs(trackFiles) do
                    if shouldStop then
                        WindUI:Notify({
                            Title = "Update Checkpoint",
                            Content = "Update dibatalkan!",
                            Duration = 3,
                            Icon = "x-circle"
                        })
                        return
                    end
                    
                    if i % 10 == 0 or i == #trackFiles then
                        WindUI:Notify({
                            Title = "Update Checkpoint",
                            Content = string.format("Progress: %d/%d", i, #trackFiles),
                            Duration = 1.5,
                            Icon = "download"
                        })
                    end
                    
                    local success, content = pcall(function()
                        return game:HttpGet(trackUrl .. file)
                    end)
                    
                    if success and content and #content > 0 then
                        writefile(trackFolder .. "/" .. file, content)
                        successCount = successCount + 1
                    else
                        failCount = failCount + 1
                    end
                    
                    task.wait(0.3)
                end
                
                if not shouldStop then
                    WindUI:Notify({
                        Title = "Update Selesai",
                        Content = string.format("Berhasil: %d | Gagal: %d", successCount, failCount),
                        Duration = 5,
                        Icon = "check-check"
                    })
                end
                
                isUpdating = false
            end)
        end
    })
    
    UpdateCheckpointTab:Divider()
end

