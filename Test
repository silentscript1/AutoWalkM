local function formatDate(dateStr)
    if not dateStr or dateStr == "" then return "N/A" end
    local parts = {dateStr:match("(%d+)-(%d+)-(%d+)")}
    if parts[1] then
        local months = {"Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"}
        return string.format("%02d %s %s", tonumber(parts[3]), months[tonumber(parts[2])] or "Unknown", parts[1])
    end
    return dateStr
end

local function maskToken(tok)
    if not tok or tok == "" then return "N/A" end
    local len = #tok
    if len <= 8 then return string.rep("*", len) end
    return tok:sub(1, 4) .. string.rep("*", len - 8) .. tok:sub(-4)
end

local function maskDisplay(str)
    if not str or str == "" then return "*****" end
    local len = #str
    if len <= 5 then return str:sub(1, 1) .. string.rep("*", len - 1) end
    return str:sub(1, 2) .. string.rep("*", len - 5) .. str:sub(-2)
end

local function formatExpiry(days)
    if days <= 0 then return "Expired" end
    if days == 1 then return "1 Day" end
    return days .. " Days"
end

local function validateToken(tok)
    if not tok or tok == "" then return false, "Token tidak boleh kosong!" end
    
    local url = auth.base_url .. "/" .. auth.validate_endpoint .. 
                "?token=" .. HttpService:UrlEncode(tok) .. 
                "&roblox_username=" .. HttpService:UrlEncode(PlayerName)
    
    local success, response = httpRequest(url, "GET")
    if not success then return false, "Connection error: " .. tostring(response) end
    
    local decodeSuccess, data = pcall(function()
        return HttpService:JSONDecode(response)
    end)
    if not decodeSuccess then return false, "Invalid server response" end
    if type(data) ~= "table" then return false, "Invalid response structure" end
    
    if tostring(data.status or ""):lower() == "success" then
        return true, data
    end
    return false, tostring(data.message or "Authentication failed")
end

local function getUserInfo(tok)
    if not tok or tok == "" then return false, "Token tidak boleh kosong!" end
    
    local url = auth.base_url .. "/" .. auth.getuser_endpoint .. "?token=" .. HttpService:UrlEncode(tok)
    local success, response = httpRequest(url, "GET")
    if not success then return false, "Connection error: " .. tostring(response) end
    
    local decodeSuccess, data = pcall(function()
        return HttpService:JSONDecode(response)
    end)
    if not decodeSuccess then return false, "Invalid response format" end
    if type(data) ~= "table" then return false, "Invalid response structure" end
    
    if tostring(data.status or ""):lower() == "success" then
        return true, data
    end
    return false, tostring(data.message or "Failed to get user info")
end

local function updateUserData(data)
