-- ==================== AUTO LOGIN ====================
local function doLogin(inputKey)
    if isAuthenticated then
        WindUI:Notify({
            Title = "Tunggu!",
            Content = "Masih dalam proses validasi...",
            Duration = 2,
            Icon = "loader"
        })
        return
    end
    
    if not inputKey or inputKey == "" then
        WindUI:Notify({
            Title = "Error",
            Content = "Key tidak boleh kosong!",
            Duration = 3,
            Icon = "triangle-alert"
        })
        return
    end
    
    isAuthenticated = true
    
    WindUI:Notify({
        Title = "Validating...",
        Content = "Pengecekan token dengan username: " .. PlayerName,
        Duration = 2,
        Icon = "shield-check"
    })
    
    local success, data = validateToken(inputKey)
    isAuthenticated = false
    
    if success then
        WindUI:Notify({
            Title = "Key Valid!",
            Content = "Authentication berhasil!",
            Duration = 3,
            Icon = "check-check"
        })
        
        saveToken(inputKey)
        getgenv().UserToken = inputKey
        getgenv().AuthComplete = true
        getgenv().AuthTimestamp = os.time()
        
        task.wait(0.5)
        
        local userSuccess, userDataResult = getUserInfo(inputKey)
        if userSuccess then
            updateUserData(userDataResult)
        end
        
        task.wait(0.5)
        
        -- Setup all tabs after successful login
        setupAccountTab()
        setupCreditsTab()
        setupBypassTab()
        setupOtherScriptsTab()
        setupAutoWalkTab()
        setupCopyAvatarTab()
        setupAnimationTab()
        setupSkyboxTab()
        setupPlayerMenuTab()
        setupSocialMediaTab()
        setupThemesUITab()
        setupUpdateCheckpointTab()
        setupLogoutTab()
        isLoggedIn = true
        
        WindUI:Notify({
            Title = "Welcome!",
            Content = "Menu utama telah terbuka. Selamat menggunakan MarV Script!",
            Duration = 3,
            Icon = "sparkles"
        })
    else
        WindUI:Notify({
            Title = "Key Salah!",
            Content = tostring(data),
            Duration = 5,
            Icon = "ban"
        })
    end
end

