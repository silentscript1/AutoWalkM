local function setupAnimationTab()
    local AnimationTab = Window:Tab({
        Title = "Animation",
        Icon = "person-standing"
    })
    
    local lastSelectedAnim = {
        Idle = "Original",
        Walk = "Original",
        Run = "Original",
        Jump = "Original"
    }
    
    local originalAnimIds = {
        Idle = {},
        Walk = "",
        Run = "",
        Jump = ""
    }
    
    local function getOriginalAnimations()
        local char = LocalPlayer.Character
        if not char then return end
        
        local animate = char:FindFirstChild("Animate")
        if not animate then return end
        
        if animate:FindFirstChild("idle") then
            originalAnimIds.Idle = {}
            for _, anim in pairs(animate.idle:GetChildren()) do
                if anim:IsA("Animation") then
                    table.insert(originalAnimIds.Idle, anim.AnimationId)
                end
            end
        end
        
        if animate:FindFirstChild("walk") then
            originalAnimIds.Walk = animate.walk.WalkAnim.AnimationId
        end
        
        if animate:FindFirstChild("run") then
            originalAnimIds.Run = animate.run.RunAnim.AnimationId
        end
        
        if animate:FindFirstChild("jump") then
            originalAnimIds.Jump = animate.jump.JumpAnim.AnimationId
        end
    end
    
    local function resetAnimations()
        local char = LocalPlayer.Character
        if not char then return end
        
        local animate = char:FindFirstChild("Animate")
        if not animate then return end
        
        if animate:FindFirstChild("idle") then
            for i, anim in pairs(animate.idle:GetChildren()) do
                if anim:IsA("Animation") and originalAnimIds.Idle[i] then
                    anim.AnimationId = originalAnimIds.Idle[i]
                end
            end
        end
        
        if animate:FindFirstChild("walk") then
            animate.walk.WalkAnim.AnimationId = originalAnimIds.Walk
        end
        
        if animate:FindFirstChild("run") then
            animate.run.RunAnim.AnimationId = originalAnimIds.Run
        end
        
        if animate:FindFirstChild("jump") then
            animate.jump.JumpAnim.AnimationId = originalAnimIds.Jump
        end
        
        for state, anim in pairs(lastSelectedAnim) do
            lastSelectedAnim[state] = "Original"
        end
    end
    
    local function applyAnimation(animType, animId)
        local char = LocalPlayer.Character
        if not char then return end
        
        local animate = char:FindFirstChild("Animate")
        if not animate then return end
        
        if animType == "Idle" then
            local idleContainer = animate:FindFirstChild("idle")
            if idleContainer then
                for i, anim in pairs(idleContainer:GetChildren()) do
                    if anim:IsA("Animation") and animId[i] then
                        anim.AnimationId = "rbxassetid://" .. animId[i]
                    end
                end
            end
        elseif animType == "Walk" then
            if animate:FindFirstChild("walk") then
                animate.walk.WalkAnim.AnimationId = "rbxassetid://" .. animId
            end
        elseif animType == "Run" then
            if animate:FindFirstChild("run") then
                animate.run.RunAnim.AnimationId = "rbxassetid://" .. animId
            end
        elseif animType == "Jump" then
            if animate:FindFirstChild("jump") then
                animate.jump.JumpAnim.AnimationId = "rbxassetid://" .. animId
            end
        end
        
        lastSelectedAnim[animType] = animId
    end
    
    LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        getOriginalAnimations()
        
        for state, anim in pairs(lastSelectedAnim) do
            if anim ~= "Original" then
                task.wait(0.2)
                applyAnimation(state, anim)
            end
        end
    end)
    
    task.spawn(function()
        if LocalPlayer.Character then
            getOriginalAnimations()
        end
    end)
    
    AnimationTab:Section({
        Title = "MarV Script | Emot Menu"
    })
    AnimationTab:Divider()
    
    AnimationTab:Paragraph({
        Title = "Emot Menu",
        Desc = "Pada emot menu ini fitur tambahan yang dimana kalian bisa menggunakan emot secara free, script emot ini dibuat oleh: Vexro Emots"
    })
    
    AnimationTab:Toggle({
        Title = "◉ OPEN EMOT MENU",
        Icon = "smile",
        Type = "Checkbox",
        Value = false,
