local function setupPlayerMenuTab()
    local PlayerMenuTab = Window:Tab({
        Title = "Player Menu",
        Icon = "user-cog"
    })
    
    local hideNametag = false
    local walkSpeedEnabled = false
    local walkSpeedValue = 16
    local lockTime = false
    local lockTimeValue = 12
    local walkSpeedConnection = nil
    local timeLockConnection = nil
    
    -- Nametag Section
    PlayerMenuTab:Section({
        Title = "Nametag Menu",
        TextTransparency = 0.05,
        TextXAlignment = "Left",
        TextSize = 17
    })
    
    local function updateNametagVisibility()
        for _, player in pairs(Players:GetPlayers()) do
            local char = player.Character
            if char then
                local head = char:FindFirstChild("Head")
                if head then
                    for _, gui in pairs(head:GetChildren()) do
                        if gui:IsA("BillboardGui") then
                            gui.Enabled = not hideNametag
                        end
                    end
                end
            end
        end
    end
    
    PlayerMenuTab:Toggle({
        Title = "Hide Nametag",
        Desc = "Berfungsi untuk menyembunyikan nametag player di semua map.",
        Icon = "check",
        Type = "Checkbox",
        Value = false,
        Callback = function(state)
            hideNametag = state
            updateNametagVisibility()
            
            if state then
                Players.PlayerAdded:Connect(function(player)
                    player.CharacterAdded:Connect(function(char)
                        task.wait(0.5)
                        local head = char:FindFirstChild("Head")
                        if head then
                            for _, gui in pairs(head:GetChildren()) do
                                if gui:IsA("BillboardGui") then
                                    gui.Enabled = false
                                end
                            end
                        end
                    end)
                end)
            end
        end
    })
    
    -- Walk Speed Section
    PlayerMenuTab:Section({
        Title = "Walk Speed Menu",
        TextTransparency = 0.05,
        TextXAlignment = "Left",
        TextSize = 17
    })
    
    PlayerMenuTab:Toggle({
        Title = "Enable Walk Speed",
        Desc = "Aktifkan enable walk speed terlebih dahulu sebelum set walk speed.",
        Icon = "check",
        Type = "Checkbox",
        Value = false,
        Callback = function(state)
            walkSpeedEnabled = state
            if state and currentHumanoid then
                currentHumanoid.WalkSpeed = walkSpeedValue
                if not walkSpeedConnection then
                    walkSpeedConnection = currentHumanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
                        if walkSpeedEnabled and currentHumanoid.WalkSpeed ~= walkSpeedValue then
                            currentHumanoid.WalkSpeed = walkSpeedValue
                        end
                    end)
                end
            elseif walkSpeedConnection then
                walkSpeedConnection:Disconnect()
                walkSpeedConnection = nil
            end
        end
    })
    
    PlayerMenuTab:Slider({
        Title = "Set Walk Speed",
        Desc = "Berfungsi mengatur kecepatan player.",
        Step = 1,
        Value = {
            Min = 16,
            Max = 65,
            Default = 16
        },
        Callback = function(value)
            walkSpeedValue = value
            if walkSpeedEnabled and currentHumanoid then
                currentHumanoid.WalkSpeed = value
            end
        end
    })
    
    -- Time Menu Section
    PlayerMenuTab:Section({
        Title = "Time Menu",
        TextTransparency = 0.05,
        TextXAlignment = "Left",
        TextSize = 17
    })
    
    PlayerMenuTab:Toggle({
        Title = "Lock Time",
        Desc = "Kunci waktu agar server tidak bisa mengubahnya.",
        Icon = "check",
        Type = "Checkbox",
        Value = false,
        Callback = function(state)
            lockTime = state
            if state then
                Lighting.TimeOfDay = string.format("%02d:00:00", math.floor(lockTimeValue))
                if not timeLockConnection then
                    timeLockConnection = Lighting:GetPropertyChangedSignal("TimeOfDay"):Connect(function()
                        if lockTime then
                            Lighting.TimeOfDay = string.format("%02d:00:00", math.floor(lockTimeValue))
                        end
                    end)
                end
            elseif timeLockConnection then
                timeLockConnection:Disconnect()
                timeLockConnection = nil
            end
        end
    })
    
    PlayerMenuTab:Slider({
        Title = "Set Time",
        Desc = "Atur waktu siang, sore, malam.",
        Step = 1,
        Value = {
            Min = 0,
            Max = 24,
            Default = 12
        },
        Callback = function(value)
            lockTimeValue = value
            Lighting.TimeOfDay = string.format("%02d:00:00", math.floor(value))
            if lockTime then
                Lighting.TimeOfDay = string.format("%02d:00:00", math.floor(value))
            end
        end
    })
    
    -- Character reset handler
    LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        currentCharacter = char
        currentHumanoid = char:FindFirstChild("Humanoid")
        currentRootPart = char:FindFirstChild("HumanoidRootPart")
        
        if walkSpeedEnabled and currentHumanoid then
            currentHumanoid.WalkSpeed = walkSpeedValue
            if walkSpeedConnection then
                walkSpeedConnection:Disconnect()
            end
            walkSpeedConnection = currentHumanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
                if walkSpeedEnabled and currentHumanoid.WalkSpeed ~= walkSpeedValue then
                    currentHumanoid.WalkSpeed = walkSpeedValue
                end
            end)
        end
        
        if hideNametag then
            task.wait(0.5)
            updateNametagVisibility()
        end
    end)
end

