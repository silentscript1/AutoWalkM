local function playFootstepSound()
    if not currentRootPart then return end
    
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {currentCharacter}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    
    local rayResult = Workspace:Raycast(currentRootPart.Position, Vector3.new(0, -5, 0), rayParams)
    if rayResult then
        local soundId = "rbxasset://sounds/action_footsteps_plastic.mp3"
        local material = rayResult.Material
        
        if material == Enum.Material.Grass then
            soundId = "rbxassetid://9118823107"
        elseif material == Enum.Material.Metal then
            soundId = "rbxassetid://260433111"
        elseif material == Enum.Material.Sand then
            soundId = "rbxassetid://9120089994"
        elseif material == Enum.Material.Wood then
            soundId = "rbxassetid://9118828605"
        end
        
        local sound = Instance.new("Sound")
        sound.SoundId = soundId
        sound.Volume = 0.8
        sound.RollOffMaxDistance = 100
        sound.RollOffMinDistance = 10
        sound.Parent = currentRootPart
        sound:Play()
        Debris:AddItem(sound, 1)
    end
end

local function onWalk()
    if not currentHumanoid or not currentRootPart then return end
    
    local moveDirection = currentHumanoid.MoveDirection
    local speed = Vector3.new(moveDirection.X, 0, moveDirection.Z).Magnitude
    local isRunning = currentHumanoid:GetState() == Enum.HumanoidStateType.Running or 
                      currentHumanoid:GetState() == Enum.HumanoidStateType.RunningNoPhysics or
                      currentHumanoid:GetState() == Enum.HumanoidStateType.Landed
    
    if speed > 0.5 and isRunning then
        local now = tick()
        if now - lastFootstepTime >= stepSoundCooldown / (math.clamp(speed / 16, 0.3, 2) * autoWalkSpeed) then
            playFootstepSound()
            lastFootstepTime = now
        end
    end
end

